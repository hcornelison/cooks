---
import { getCollection, render } from 'astro:content';
import { Image } from 'astro:assets';
import Layout from '../../layouts/Layout.astro';
import { renderInline } from '../../utils/markdown';
import { getRecipeImage } from '../../utils/images';

export async function getStaticPaths() {
  const recipes = await getCollection('recipes');
  const components = await getCollection('components');
  return recipes.map((recipe) => ({
    params: { id: recipe.id },
    props: { recipe, components },
  }));
}

const { recipe, components } = Astro.props;
const { title, image, yield: recipeYield, preptime, cooktime, ingredients, directions, notes, components: componentNames, category } = recipe.data;
const { Content } = await render(recipe);

const parts = (componentNames ?? [])
  .map((name) => components.find((c) => c.data.title === name))
  .filter(Boolean);

const hasScalableIngredients =
  (ingredients && ingredients.length > 0) || parts.some((p) => p!.data.ingredients.length > 0);
---
<Layout title={title}>
  <div class="container" itemscope itemtype="http://schema.org/Recipe" style="padding-top: 1.5rem;">
    <Image
      class="recipe-hero-image"
      itemprop="image"
      src={getRecipeImage(image)}
      alt={title}
      width={1000}
      format="webp"
      quality={80}
      loading="eager"
    />

    <h1 class="post-title" itemprop="name">{title}</h1>

    <div class="recipe-meta-strip">
      {recipeYield && (
        <div class="recipe-meta-item" itemprop="yield">
          <span class="recipe-meta-label">Servings</span>
          <span class="recipe-meta-value">{recipeYield}</span>
        </div>
      )}
      {preptime && (
        <div class="recipe-meta-item">
          <span class="recipe-meta-label">Prep Time</span>
          <span class="recipe-meta-value">{preptime}</span>
        </div>
      )}
      {cooktime && (
        <div class="recipe-meta-item">
          <span class="recipe-meta-label">Cooking Time</span>
          <span class="recipe-meta-value">{cooktime}</span>
        </div>
      )}
    </div>

    {hasScalableIngredients && (
      <div class="select-scale global-scale">
        <select>
          <option value="0.5">&frac12;</option>
          <option selected value="1">1</option>
          <option value="1.5">1 &frac12;</option>
          <option value="2">2</option>
          <option value="3">3</option>
          <option value="4">4</option>
          <option value="5">5</option>
        </select>
      </div>
    )}

    <div class="wake-lock-row">
      <button type="button" id="wake-lock-toggle" class="wake-lock-toggle" aria-pressed="false" hidden>
        <span aria-hidden="true">☀️</span>
        <span class="wake-lock-label">Keep Screen Awake</span>
      </button>
      <button type="button" id="checklist-reset" class="wake-lock-toggle" hidden>
        <span aria-hidden="true">🔄</span>
        <span>Clear Checks</span>
      </button>
    </div>

    {parts.length > 0 && (
      <details class="full-ingredient-list">
        <summary>View full ingredient list</summary>
        {ingredients && ingredients.length > 0 && (
          <div class="full-ingredient-group">
            <h4>{title}</h4>
            <ul class="ingredients-list">
              {ingredients.map((ingredient) => (
                <li data-ingredient-text={ingredient}>
                  <input type="checkbox" />
                  <span class="ingredient-label">{ingredient}</span>
                </li>
              ))}
            </ul>
          </div>
        )}
        {parts.map((part, i) => (
          <div class="full-ingredient-group">
            <h4>Part {i + 1}: {part!.data.title}</h4>
            <ul class="ingredients-list">
              {part!.data.ingredients.map((ingredient) => (
                <li data-ingredient-text={ingredient}>
                  <input type="checkbox" />
                  <span class="ingredient-label">{ingredient}</span>
                </li>
              ))}
            </ul>
          </div>
        ))}
      </details>
    )}

    {parts.length === 0 ? (
      <div class="recipe-columns">
        {ingredients && ingredients.length > 0 && (
          <div>
            <h3>Ingredients</h3>
            <ul class="ingredients-list" itemprop="recipeIngredient">
              {ingredients.map((ingredient) => (
                <li data-ingredient-text={ingredient}>
                  <input type="checkbox" />
                  <span class="ingredient-label">{ingredient}</span>
                </li>
              ))}
            </ul>
          </div>
        )}

        {directions && directions.length > 0 && (
          <div>
            <h3>Directions</h3>
            <ul class="directions-list" itemprop="recipeInstructions">
              {directions.map((direction) => (
                <li>
                  <input type="checkbox" />
                  <span set:html={renderInline(direction)} />
                </li>
              ))}
            </ul>
          </div>
        )}
      </div>
    ) : (
      <>
        {ingredients && ingredients.length > 0 && (
          <div class="recipe-columns">
            <div>
              <h3>Ingredients</h3>
              <ul class="ingredients-list" itemprop="recipeIngredient">
                {ingredients.map((ingredient) => (
                  <li data-ingredient-text={ingredient}>
                    <input type="checkbox" />
                    <span class="ingredient-label">{ingredient}</span>
                  </li>
                ))}
              </ul>
            </div>
          </div>
        )}

        <div class="recipe-parts">
          {parts.map((part, i) => (
            <section class="recipe-part">
              <h2 class="recipe-part-title">
                <span class="recipe-part-number">Part {i + 1}</span>
                {part!.data.title}
              </h2>
              <div class="recipe-columns">
                <div>
                  <h3>Ingredients</h3>
                  <ul class="ingredients-list" itemprop="recipeIngredient">
                    {part!.data.ingredients.map((ingredient) => (
                      <li data-ingredient-text={ingredient}>
                        <input type="checkbox" />
                        <span class="ingredient-label">{ingredient}</span>
                      </li>
                    ))}
                  </ul>
                </div>
                <div>
                  <h3>Directions</h3>
                  <ul class="directions-list">
                    {part!.data.directions.map((direction) => (
                      <li>
                        <input type="checkbox" />
                        <span set:html={renderInline(direction)} />
                      </li>
                    ))}
                  </ul>
                </div>
              </div>
            </section>
          ))}
        </div>

        {directions && directions.length > 0 && (
          <div class="assembly-section">
            <h3>Assembly</h3>
            <ul class="directions-list" itemprop="recipeInstructions">
              {directions.map((direction) => (
                <li>
                  <input type="checkbox" />
                  <span set:html={renderInline(direction)} />
                </li>
              ))}
            </ul>
          </div>
        )}
      </>
    )}

    {notes && notes.length > 0 && (
      <div class="notes-section">
        <h3>Notes</h3>
        <ul class="notes-list">
          {notes.map((note) => (
            <li>
              <input type="checkbox" />
              <span set:html={renderInline(note)} />
            </li>
          ))}
        </ul>
      </div>
    )}

    <Content />

    {category && <p class="recipe-category">Category: <span itemprop="recipeCategory">{category}</span></p>}
  </div>
</Layout>

<script src="/js/scale-recipes.js" type="module"></script>
<script src="/js/checklist.js" type="module"></script>
<script src="/js/wake-lock.js" is:inline></script>
