---
import { getCollection } from 'astro:content';
import { Image } from 'astro:assets';
import Layout from '../layouts/Layout.astro';
import { getRecipeImage } from '../utils/images';

const recipes = (await getCollection('recipes')).sort((a, b) => a.data.title.localeCompare(b.data.title));

function tagsOf(recipe: (typeof recipes)[number]) {
  return recipe.data.tags.split(',').map((t) => t.trim()).filter(Boolean);
}

const allTags = [...new Set(recipes.flatMap(tagsOf))].sort((a, b) => a.localeCompare(b));
---
<Layout>
  <div class="tag-filter-bar" role="group" aria-label="Filter recipes by category">
    <button type="button" class="tag-filter-btn active" data-tag="all" aria-pressed="true">All</button>
    {allTags.map((tag) => (
      <button type="button" class="tag-filter-btn" data-tag={tag} aria-pressed="false">{tag}</button>
    ))}
  </div>
  <div class="recipes-grid" id="recipes-grid">
    {recipes.map((recipe) => (
      <a class="recipe-card" href={`/recipes/${recipe.id}`} data-tags={tagsOf(recipe).join(',')}>
        <div class="card-image-wrap">
          <Image
            src={getRecipeImage(recipe.data.image)}
            alt={recipe.data.title}
            width={500}
            format="webp"
            quality={75}
            class="card-image"
          />
        </div>
        <h1 class="title"><span class="title-text">{recipe.data.title}</span></h1>
      </a>
    ))}
  </div>
  <p class="filter-empty-state" id="filter-empty-state" hidden>No recipes match that category yet.</p>
  <div class="page-intro">
    <p>
      This is a personal collection of recipes. Not all of these recipes are original, and the recipes
      from other sites are ones that I pulled so I could make notes on them and keep them together in a
      single collection.
    </p>
  </div>
</Layout>

<script src="/js/tag-filter.js" is:inline></script>
