---
import { repoUrl, commitHash, commitHashShort } from '../utils/git';
const { title } = Astro.props;
---
<footer class="site-footer">
  <div class="site-footer-inner">
    <p class="site-footer-title">{title}</p>
    <nav class="site-footer-links">
      <a href="/search">Search</a>
      <a href="/categories">Categories</a>
    </nav>
    <p class="site-footer-meta">
      <a href={repoUrl} target="_blank" rel="noopener noreferrer">Source on GitHub</a>
      {commitHashShort && (
        <>
          {' · '}
          <a href={`${repoUrl}/commit/${commitHash}`} target="_blank" rel="noopener noreferrer">
            {commitHashShort}
          </a>
        </>
      )}
    </p>
  </div>
  <script src="/js/theme.js" is:inline></script>
</footer>
